          {
            "id": "klaw-encounter",
            "label": "Klaw Encounter",
            "data": { "pack": "marvelchampions-klaw", "cardSet": "klaw-encounter" }
          },
          {
            "id": "ultron-encounter",
            "label": "Ultron Encounter",
            "data": { "pack": "marvelchampions-ultron", "cardSet": "ultron-encounter" }
          }
