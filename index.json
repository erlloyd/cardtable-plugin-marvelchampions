            "data": { "pack": "marvelchampions-doomsday-chair", "cardSet": "doomsday-chair" }
          },
          {
            "id": "standard-encounter",
            "label": "Standard Encounter",
            "data": { "pack": "marvelchampions-standard-encounter", "cardSet": "standard-encounter" }
          },
          {
